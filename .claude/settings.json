{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "*",
      "Bash(yarn workspace:*)",
      "Bash(npx tsc:*)",
      "Bash(echo \"EXIT: $?\")",
      "Read(//home/anderson/**)",
      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); print\\(d.get\\('packageManager', 'not set'\\)\\)\")",
      "Bash(~/.local/share/pnpm/pnpm --filter @ledger/shared build)",
      "Bash(pnpm c:*)",
      "Bash(pnpm env:*)",
      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); print\\(json.dumps\\(d, indent=2\\)\\)\")",
      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); print\\(json.dumps\\({k: d[k] for k in ['scripts'] if k in d}, indent=2\\)\\)\")",
      "Bash(pnpm prisma:migrate)",
      "Bash(pnpm prisma:migrate:deploy)",
      "Bash(kill 15944 15969 16003)",
      "Bash(PGPASSWORD=ledger psql -h localhost -U ledger -d ledger -c \"\\\\dt public.*\")"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(chown *)",
      "Bash(docker system prune *)",
      "Bash(git push --force)",
      "Bash(git reset --hard *)"
    ],
    "ask": [
      "Bash(node ace migration:run *)",
      "Bash(node ace db:seed *)",
      "Bash(node ace db:rollback *)",
      "Bash(node ace db:refresh *)",
      "Bash(node ace db:wipe *)",
      "Bash(node ace db:create *)",
      "Bash(yarn)",
      "Bash(yarn install *)",
      "Bash(npm install *)",
      "Bash(pnpm install *)",
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(docker *)"
    ],
    "additionalDirectories": [
      "/home/anderson/apps/ledger/apps/web/src/app/(protected)/wallets",
      "/home/anderson/apps/ledger/apps/web/src/app/(protected)/wallets/[id]"
    ]
  },
  "defaultMode": "acceptEdits"
}
