# =============================================================================
# @ledger/api — Environment Variables
#
# LOCAL DEV:
#   This file is NOT used directly. Create a symlink instead:
#   ln -sf ../../.env apps/api/.env
#   (Prisma CLI requires a .env file in the app directory)
#
# PRODUCTION (EasyPanel):
#   Configure each variable below in the EasyPanel API service environment.
#   No .env file is needed — EasyPanel injects vars directly.
# =============================================================================

# ---- Runtime ----
NODE_ENV=production
PORT=3000

# ---- Database (PostgreSQL) ----
# EasyPanel: use the internal hostname of your Postgres service
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ledger?schema=public"

# ---- Redis ----
# EasyPanel: use the internal hostname of your Redis service
REDIS_URL="redis://HOST:6379"

# ---- RabbitMQ ----
# EasyPanel: use the internal hostname of your RabbitMQ service
RABBITMQ_URL="amqp://USER:PASSWORD@HOST:5672"

# ---- Auth ----
SESSION_TTL_DAYS=30
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_MAX=3
OTP_RATE_LIMIT_WINDOW_MINUTES=10

# ---- Email (Resend) ----
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@yourdomain.com
