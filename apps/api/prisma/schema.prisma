generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Auth Domain
// =============================================================================

model User {
  id          String      @id @default(uuid())
  email       String      @unique
  status      UserStatus  @default(active)
  lastLoginAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  otps              UserOtp[]
  sessions          AuthSession[]
  ownedWallets      Wallet[]       @relation("WalletOwner")
  walletMemberships WalletMember[] @relation("WalletMemberUser")
  sentInvitations   WalletMember[] @relation("WalletMemberInvitedBy")

  @@map("users")
}

model UserOtp {
  id        String    @id @default(uuid())
  userId    String?
  email     String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([email])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("user_otps")
}

model AuthSession {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  lastSeenAt DateTime?
  ip         String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

enum UserStatus {
  active
  inactive
  blocked
}

// =============================================================================
// Wallets Domain
// =============================================================================

enum WalletType {
  personal
  home
  business
  family
  project
  custom
}

enum WalletMemberRole {
  owner
  editor
  viewer
}

enum WalletMemberStatus {
  invited
  active
  revoked
}

model Wallet {
  id             String     @id @default(uuid())
  ownerUserId    String
  name           String     @db.VarChar(150)
  type           WalletType @default(personal)
  currencyCode   String     @default("BRL") @db.VarChar(10)
  initialBalance Decimal    @default(0) @db.Decimal(14, 2)
  description    String?
  isArchived     Boolean    @default(false)
  archivedAt     DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  owner                 User                   @relation("WalletOwner", fields: [ownerUserId], references: [id])
  members               WalletMember[]
  categories            Category[]
  bankAccounts          BankAccount[]
  transactions          Transaction[]
  creditCards           CreditCard[]
  faturas               Fatura[]
  recurringTransactions RecurringTransaction[]
  budgets               Budget[]

  @@index([ownerUserId])
  @@index([isArchived])
  @@map("wallets")
}

model WalletMember {
  id              String             @id @default(uuid())
  walletId        String
  userId          String?
  role            WalletMemberRole
  status          WalletMemberStatus @default(invited)
  invitedEmail    String?            @db.VarChar(255)
  invitedByUserId String?
  invitedAt       DateTime?
  revokedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  wallet    Wallet @relation(fields: [walletId], references: [id])
  user      User?  @relation("WalletMemberUser", fields: [userId], references: [id])
  invitedBy User?  @relation("WalletMemberInvitedBy", fields: [invitedByUserId], references: [id])

  @@index([walletId])
  @@index([userId])
  @@index([status])
  @@index([invitedEmail])
  @@index([walletId, userId])
  @@index([walletId, invitedEmail])
  @@map("wallet_members")
}

// =============================================================================
// Transactions Domain
// =============================================================================

enum TransactionType {
  income
  expense
  transfer_in
  transfer_out
  credit_card_purchase
  invoice_payment
  credit_card_refund
}

enum TransactionStatus {
  pending
  paid
  canceled
}

enum CategoryType {
  income
  expense
  any
}

enum BankAccountType {
  checking
  savings
  credit_card
  cash
  investment
  other
}

model Category {
  id         String       @id @default(uuid())
  walletId   String
  name       String       @db.VarChar(100)
  color      String?      @db.VarChar(7)
  icon       String?      @db.VarChar(50)
  type       CategoryType @default(any)
  isArchived Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  wallet                Wallet                 @relation(fields: [walletId], references: [id])
  transactions          Transaction[]
  purchases             CreditCardPurchase[]
  recurringTransactions RecurringTransaction[]
  budgets               Budget[]

  @@unique([walletId, name])
  @@index([walletId])
  @@map("categories")
}

model BankAccount {
  id            String          @id @default(uuid())
  walletId      String
  name          String          @db.VarChar(150)
  type          BankAccountType @default(checking)
  institution   String?         @db.VarChar(100)
  accountNumber String?         @db.VarChar(50)
  isArchived    Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  wallet                Wallet                 @relation(fields: [walletId], references: [id])
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]

  @@index([walletId])
  @@map("bank_accounts")
}

model Transaction {
  id                  String            @id @default(uuid())
  walletId            String
  categoryId          String?
  bankAccountId       String?
  type                TransactionType
  status              TransactionStatus @default(pending)
  amount              Decimal           @db.Decimal(14, 2)
  sign                Int
  description         String?           @db.VarChar(255)
  notes               String?           @db.Text
  dueDate             DateTime          @db.Date
  paidAt              DateTime?
  transferGroupId     String?
  recurrenceId        String?
  recurrenceIndex     Int?
  // Credit-card unification: a credit_card_purchase transaction belongs to a
  // fatura and a purchase header that groups all parcelas of the same compra.
  faturaId            String?
  purchaseId          String?
  installmentNumber   Int?
  totalInstallments   Int?
  deletedAt           DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  wallet                 Wallet                @relation(fields: [walletId], references: [id])
  category               Category?             @relation(fields: [categoryId], references: [id])
  bankAccount            BankAccount?          @relation(fields: [bankAccountId], references: [id])
  recurringTransaction   RecurringTransaction? @relation(fields: [recurrenceId], references: [id])
  fatura                 Fatura?               @relation("FaturaInstallmentTx", fields: [faturaId], references: [id])
  purchase               CreditCardPurchase?   @relation("PurchaseInstallmentTx", fields: [purchaseId], references: [id])
  invoicePaymentFatura   Fatura?               @relation("FaturaPaymentTx")

  @@index([walletId, status])
  @@index([walletId, dueDate])
  @@index([walletId, type])
  @@index([transferGroupId])
  @@index([recurrenceId])
  @@index([faturaId])
  @@index([purchaseId])
  @@map("transactions")
}

// =============================================================================
// Recurring Transactions Domain
// =============================================================================

enum RecurrenceFrequency {
  daily
  weekly
  biweekly
  monthly
}

model RecurringTransaction {
  id                String              @id @default(uuid())
  walletId          String
  type              TransactionType
  frequency         RecurrenceFrequency
  description       String              @db.VarChar(255)
  amount            Decimal             @db.Decimal(14, 2)
  categoryId        String?
  bankAccountId     String?
  notes             String?             @db.Text
  startDate         DateTime            @db.Date
  endDate           DateTime?           @db.Date
  maxOccurrences    Int?
  lastGeneratedDate DateTime?           @db.Date
  isActive          Boolean             @default(true)
  deletedAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  wallet      Wallet        @relation(fields: [walletId], references: [id])
  category    Category?     @relation(fields: [categoryId], references: [id])
  bankAccount BankAccount?  @relation(fields: [bankAccountId], references: [id])
  occurrences Transaction[]

  @@index([walletId])
  @@index([walletId, isActive])
  @@map("recurring_transactions")
}

// =============================================================================
// Credit Cards Domain
// =============================================================================

enum PurchaseStatus {
  active
  canceled
}

model CreditCard {
  id               String   @id @default(uuid())
  walletId         String
  name             String   @db.VarChar(150)
  closingDay       Int
  dueDay           Int
  creditLimitCents Int?
  isArchived       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  wallet    Wallet               @relation(fields: [walletId], references: [id])
  faturas   Fatura[]
  purchases CreditCardPurchase[]

  @@index([walletId])
  @@index([walletId, isArchived])
  @@map("credit_cards")
}

model Fatura {
  id                 String    @id @default(uuid())
  cardId             String
  walletId           String
  referenceMonth     String    @db.VarChar(7)
  closingDate        DateTime  @db.Date
  dueDate            DateTime  @db.Date
  invoicePaymentTxId String?   @unique
  paidAt             DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  card             CreditCard    @relation(fields: [cardId], references: [id])
  wallet           Wallet        @relation(fields: [walletId], references: [id])
  invoicePaymentTx Transaction?  @relation("FaturaPaymentTx", fields: [invoicePaymentTxId], references: [id])
  transactions     Transaction[] @relation("FaturaInstallmentTx")

  @@unique([cardId, referenceMonth])
  @@index([walletId, cardId])
  @@index([cardId, dueDate])
  @@map("faturas")
}

model CreditCardPurchase {
  id               String         @id @default(uuid())
  cardId           String
  walletId         String
  description      String         @db.VarChar(255)
  totalAmountCents Int
  installmentCount Int
  purchaseDate     DateTime       @db.Date
  categoryId       String?
  notes            String?        @db.Text
  status           PurchaseStatus @default(active)
  canceledAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  card         CreditCard    @relation(fields: [cardId], references: [id])
  category     Category?     @relation(fields: [categoryId], references: [id])
  transactions Transaction[] @relation("PurchaseInstallmentTx")

  @@index([walletId, cardId])
  @@index([walletId, status])
  @@index([cardId, purchaseDate])
  @@map("credit_card_purchases")
}

// =============================================================================
// Budgets Domain
// =============================================================================

model Budget {
  id          String   @id @default(uuid())
  walletId    String
  categoryId  String
  amountCents Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wallet   Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([walletId, categoryId])
  @@index([walletId])
  @@map("budgets")
}
