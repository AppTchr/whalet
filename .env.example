# =============================================================================
# LEDGER — Root .env (local development only)
# Copy to .env and fill in values.
# In production (EasyPanel), all vars are set per-service — no .env file needed.
#
# Variables are consumed by apps/api via envFilePath: '../../.env'
# =============================================================================

# --- Docker local infra ---
POSTGRES_USER=ledger
POSTGRES_PASSWORD=ledger
POSTGRES_DB=ledger
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379

RABBITMQ_USER=ledger
RABBITMQ_PASSWORD=ledger
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# --- API ---
# See apps/api/.env.example for the full API variable reference
NODE_ENV=development
PORT=3000
DATABASE_URL="postgresql://ledger:ledger@localhost:5432/ledger?schema=public"
REDIS_URL="redis://localhost:6379"
RABBITMQ_URL="amqp://ledger:ledger@localhost:5672"
SESSION_TTL_DAYS=30
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_MAX=3
OTP_RATE_LIMIT_WINDOW_MINUTES=10
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@yourdomain.com
