# Dependencies — never copy into image (installed inside Docker)
node_modules
**/node_modules

# Build outputs — rebuilt inside Docker
dist
**/.next
**/dist

# Development & local env files — secrets stay out of images
.env
.env.*
!**/.env.example

# Prisma generated client — regenerated inside Docker
**/generated

# Test and coverage artifacts
coverage
**/.nyc_output

# Editor & OS noise
.vscode
.idea
.DS_Store
*.log

# Git history — not needed in image
.git
.gitignore

# CI/CD config — not needed in image
.github
.husky

# Documentation
docs
*.md
!README.md

# Monorepo tooling files not needed in image
.turbo
turbo.json
